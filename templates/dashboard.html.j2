<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>企業調査ダッシュボード — {{ company }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="dashboard.css">
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <div class="header-title">
        <p class="eyebrow">企業調査ダッシュボード</p>
        <h1>{{ company }}</h1>
      </div>
      <div class="header-meta">
        <div><span class="label">調査日</span><span class="value">{{ surveyed_at }}</span></div>
        <div><span class="label">モデル</span><span class="value">{{ model }}</span></div>
      </div>
    </div>
  </header>

  <main class="container">
    {% if hero_screening %}
    <section class="hero-screening" aria-label="総合スクリーニング結果">
      <h2 class="hero-title">総合スクリーニング</h2>
      <div class="hero-grid">
        {% for card in hero_screening %}
        <article class="hero-card hero-{{ {'🟢':'green','🟡':'yellow','🔴':'red','⚪':'gray'}[card.badge] if card.badge in ['🟢','🟡','🔴','⚪'] else 'gray' }}">
          <div class="hero-card-top">
            <span class="hero-badge">{{ card.badge }}</span>
            <span class="hero-level">{{ card.level_label }}</span>
          </div>
          <h3 class="hero-card-axis">{{ card.axis }}</h3>
          <p class="hero-card-summary">{{ card.summary }}</p>
        </article>
        {% endfor %}
      </div>
      <p class="hero-legend">🟢 懸念なし / 🟡 要確認 / 🔴 重大懸念 / ⚪ 情報なし</p>
    </section>
    {% endif %}

    {% if sections %}
    <div class="toolbar">
      <nav class="tabs" role="tablist">
        {% for section in sections %}
        <button
          type="button"
          role="tab"
          class="tab-button {% if loop.first %}active{% endif %}"
          data-tab="{{ section.id }}"
        >{{ section.label }}</button>
        {% endfor %}
      </nav>
      <div class="display-toggle" role="group" aria-label="表示密度">
        <button type="button" class="toggle-btn active" data-mode="full">全文</button>
        <button type="button" class="toggle-btn" data-mode="compact">要点のみ</button>
      </div>
    </div>

    <div class="content-wrapper">
      <div class="content-main">
        {% for section in sections %}
        <section
          id="tab-{{ section.id }}"
          class="tab-panel {% if loop.first %}active{% endif %}"
          role="tabpanel"
        >
          <div class="markdown-body">
            {{ section.html | safe }}
          </div>
        </section>
        {% endfor %}
      </div>
      <aside class="toc-sidebar" aria-label="目次">
        <h4 class="toc-title">目次</h4>
        <ol class="toc-list"></ol>
      </aside>
    </div>
    {% else %}
    <div class="empty-state">
      <p>レポートデータがありません。</p>
    </div>
    {% endif %}
  </main>

  <footer class="site-footer">
    <p>Generated by <code>company-research</code></p>
    <p class="footer-cta">
      <button class="cta-link" onclick="reResearch()">🔄 この企業を再調査</button>
      <a href="https://claude.ai/code/session_01LHb1wK4NT9R2obTLpc5LRY" class="cta-link" target="_blank" rel="noopener noreferrer">+ 新しい調査を開始</a>
    </p>
  </footer>
  <div id="copy-toast" style="
    display:none; position:fixed; bottom:80px; left:50%; transform:translateX(-50%);
    background:rgba(0,0,0,.78); color:#fff; font-size:.85rem; padding:8px 18px;
    border-radius:20px; white-space:nowrap; z-index:200; pointer-events:none;">
    コマンドをコピーしました ✓
  </div>
  <script>
  function reResearch() {
    const company = {{ company | tojson }};
    const cmd = '/企業調査-フル ' + company;
    navigator.clipboard.writeText(cmd).then(() => {
      const toast = document.getElementById('copy-toast');
      toast.textContent = '「' + cmd + '」をコピーしました ✓';
      toast.style.display = 'block';
      setTimeout(() => { toast.style.display = 'none'; }, 2500);
    }).catch(() => {
      prompt('以下のコマンドをコピーしてチャットに貼り付けてください:', cmd);
    });
    window.open('https://claude.ai/code/session_01LHb1wK4NT9R2obTLpc5LRY', '_blank');
  }
  </script>

  <script src="dashboard.js"></script>
</body>
</html>
